# GITHUB_TOKEN: Required to write feedback to the repository.
# Users should generate a Personal Access Token (PAT) with repo scope.
GITHUB_TOKEN=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this from secrets as GEMINI_API_KEY.
# On Vercel, manually add VITE_GEMINI_API_KEY to project settings.
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=
